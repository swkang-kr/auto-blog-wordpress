# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API (https://aistudio.google.com)
GEMINI_API_KEY=AIzaSyxxxxx

# WordPress
WP_URL=https://your-wordpress-site.com
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Options
TRENDS_GEO=US
LOG_LEVEL=info

# Google Analytics 4 (optional)
GA_MEASUREMENT_ID=

# Search Engine Verification (optional)
GOOGLE_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=

# Site Info (for AdSense required pages & author byline)
SITE_NAME=TrendHunt
# Optional: override auto-generated tagline (e.g. "Korea's #1 Source for K-Beauty & K-Entertainment")
# If blank, auto-generates: "Your Source for K-Beauty, K-Entertainment Insights"
SITE_TAGLINE=
SITE_OWNER=
CONTACT_EMAIL=

# X (Twitter) API - optional, enables auto-promotion tweets after each post
# Get credentials at: https://developer.twitter.com/en/portal/dashboard
# Required permissions: Read and Write
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Google Indexing API - optional, requests Google to index new posts immediately
# 1. Google Cloud Console > IAM > Service Accounts > Create
# 2. Grant "Owner" or "Indexing API" role
# 3. Create JSON key, paste the entire JSON as a single line below
GOOGLE_INDEXING_SA_KEY=

# DEV.to - optional, auto-syndicate article with canonical URL (no SEO penalty)
# Get API key at: https://dev.to/settings/extensions → DEV Community API Keys
DEVTO_API_KEY=

# Hashnode - optional, auto-syndicate article with canonical URL (no SEO penalty)
# Get token at: https://hashnode.com/settings/developer → Personal Access Tokens
HASHNODE_TOKEN=
# Publication ID: Go to your blog dashboard → Settings → copy the publication ID from the URL
HASHNODE_PUBLICATION_ID=

# Content Quality & Workflow
# Minimum quality score (0-100) for a post to be published. Posts below this are rejected and regenerated.
MIN_QUALITY_SCORE=60
# Publish status: "publish" for immediate, "draft" for manual review before publishing
PUBLISH_STATUS=publish
# Minutes between publishing each post (0 = all at once, 120 = 2-hour intervals)
PUBLISH_INTERVAL_MINUTES=0
# Optimal publish hour (24h format, target audience peak time). Default 8 AM ET for US readers.
PUBLISH_OPTIMAL_HOUR=8
# Timezone for publish scheduling (IANA timezone name)
PUBLISH_TIMEZONE=America/New_York

# Author Identity (E-E-A-T enhancement)
# LinkedIn profile URL (e.g., https://linkedin.com/in/your-profile)
AUTHOR_LINKEDIN=
# X/Twitter profile URL (e.g., https://x.com/your-handle)
AUTHOR_TWITTER=
# Author website URL
AUTHOR_WEBSITE=

# YouTube Data API - optional, enables auto-embed of relevant YouTube videos in posts
# Get API key at: Google Cloud Console > APIs & Services > YouTube Data API v3
YOUTUBE_API_KEY=

# Lead Magnet - optional, injects category-specific download CTA in posts
# URL to free resource (ebook, checklist, guide) for email capture
LEAD_MAGNET_URL=
# Display title for the lead magnet CTA
LEAD_MAGNET_TITLE=

# GA4 Data API - optional, enables performance feedback loop for keyword research
# GA4 Property ID (numeric, found in GA4 Admin > Property Settings)
GA4_PROPERTY_ID=

# Google Search Console - optional, enables search query/position feedback for keyword research
# Site URL as registered in GSC (e.g., https://your-site.com or sc-domain:your-site.com)
# Uses the same GOOGLE_INDEXING_SA_KEY service account (add it as a user in GSC)
GSC_SITE_URL=

# Slack Alerting - optional, sends batch completion/failure notifications
# Create an Incoming Webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Image Format - "webp" (default, widely supported) or "avif" (better compression, newer)
IMAGE_FORMAT=webp

# Auto-Rewrite - automatically refresh underperforming posts (0 = disabled)
# Rewrites bottom 20% pageview posts or those with >70% bounce rate
AUTO_REWRITE_COUNT=2
AUTO_REWRITE_MIN_AGE_DAYS=30

# Newsletter Form URL - optional, enables email subscription CTA in posts
# Supports Mailchimp, ConvertKit, or any form action URL
NEWSLETTER_FORM_URL=

# Affiliate Links - optional, JSON mapping of brand/product keywords to affiliate URLs
# Example: {"Coupang":"https://link.coupang.com/aff?id=xxx","Toss":"https://toss.im/ref=xxx"}
AFFILIATE_MAP=

# Reddit Auto-Posting - optional, auto-submit links to relevant subreddits
# Requires a Reddit "script" type app: https://www.reddit.com/prefs/apps
# Uses REDDIT_CLIENT_ID / REDDIT_CLIENT_SECRET (same as trends API) + account credentials below
REDDIT_POST_USERNAME=
REDDIT_POST_PASSWORD=
